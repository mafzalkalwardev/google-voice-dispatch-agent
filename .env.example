# GoogleVoiceAgent environment example
GROQ_API_KEY=your_groq_api_key_here
GROQ_API_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile
CONTACTS_FILE=data/contacts.xlsx
PROFILE_NAME=sales_profile
CALLBACK_NUMBER=+15551234567
AGENT_NAME=Tony
COMPANY_NAME=Indus Transports LLC
COMPANY_WEBSITE=https://industransports.online/
COMPANY_CONTEXT="Indus Transports LLC helps owner-operators and small trucking companies find high-paying freight loads nationwide with dedicated dispatchers, rate negotiation, paperwork/payment support, all equipment types, 48-state coverage, and 24/7 support. Website says carriers can average $12K+ weekly gross, but do not guarantee earnings."
ROTATION_MINUTES=60
AUTOCUT_SECONDS=15
ANSWERED_SPEAK_DELAY_SECONDS=1.5
WAIT_FOR_HUMAN_AUDIO=true
HUMAN_AUDIO_TIMEOUT_SECONDS=8
ANSWER_CONFIRM_POLLS=2
MIN_RING_SECONDS=0
MAX_RING_SECONDS=45
VOICEMAIL_DETECT_SECONDS=15
CALL_COOLDOWN_SECONDS=10

# Realtime conversation settings
# CAPTURE_DEVICE: "default" = WASAPI loopback on system speaker (single-cable setup)
#                 "CABLE B Output" = dedicated capture cable (dual-cable setup, recommended)
CAPTURE_DEVICE=default
TTS_VOICE=en-US-GuyNeural
STT_MODEL=whisper-large-v3-turbo
VAD_THRESHOLD=0.015
VAD_SILENCE_FRAMES=12
VAD_SPEECH_FRAMES=2
STT_RETRY_COUNT=2
TTS_WARMUP=true
